# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ---------------------------------------------------------------------------
# Secrets / local config
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local

# ---------------------------------------------------------------------------
# Vector store + BM25 cache (regenerated by `python -m backend.ingestion.pipeline`)
# ---------------------------------------------------------------------------
.chroma/
.chroma.*
# ---------------------------------------------------------------------------
# Uploaded documents (PDF / TXT / MD) — written by POST /ingest into ./data,
# chunked into Chroma, then never re-read at runtime. Ignore the raw files
# so they don't bloat the repo; keep only the seeded fixtures.
# ---------------------------------------------------------------------------
data/uploads/
data/*.pdf
data/*.PDF
data/*.txt
data/*.md
!data/faq.json
!data/orders.json
!data/products.json

# ---------------------------------------------------------------------------
# Logs (rotating JSON logs, written by backend/observability/logging_config.py
# to LOG_DIR, default ./logs)
# ---------------------------------------------------------------------------
logs/
docs/
# ---------------------------------------------------------------------------
# Test / coverage / tooling caches
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Puku (this assistant) internal state — local-only
# ---------------------------------------------------------------------------
.puku/

# ---------------------------------------------------------------------------
# Ad-hoc smoke / probe scripts that I drop at the repo root while debugging.
# Anything matching `smoke*.py` is treated as scratch — recreate as needed.
# ---------------------------------------------------------------------------
/smoke*.py
/scripts_smoke.ps1
