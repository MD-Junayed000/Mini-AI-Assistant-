# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ---------------------------------------------------------------------------
# Secrets / local config
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local

# ---------------------------------------------------------------------------
# Vector store + BM25 cache (regenerated by `python -m backend.ingestion.pipeline`)
# ---------------------------------------------------------------------------
.chroma/

# ---------------------------------------------------------------------------
# Logs (rotating JSON logs, written by backend/observability/logging_config.py
# to LOG_DIR, default ./logs)
# ---------------------------------------------------------------------------
logs/

# ---------------------------------------------------------------------------
# Test / coverage / tooling caches
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Puku (this assistant) internal state — local-only
# ---------------------------------------------------------------------------
.puku/

# ---------------------------------------------------------------------------
# Ad-hoc smoke / probe scripts that I drop at the repo root while debugging.
# Anything matching `smoke*.py` is treated as scratch — recreate as needed.
# ---------------------------------------------------------------------------
/smoke*.py
/scripts_smoke.ps1
