# =============================================================================
# Mini AI Assistant — environment variables (copy to .env, do NOT commit real)
# =============================================================================

# --- LLM (Ollama Cloud, OpenAI-compatible) ---------------------------------
# Browse live model tags with:  curl https://ollama.com/api/tags | jq '.models[].name'
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-key
OLLAMA_PRIMARY_MODEL=gpt-oss:20b            # 13 GB, fastest free-tier answer
OLLAMA_FALLBACK_MODEL=gpt-oss:120b           # heavier, used if primary fails
OLLAMA_TIMEOUT_SECONDS=30

# --- Embeddings (Hugging Face Inference Providers, free tier) ---------------
HF_INFERENCE_BASE_URL=https://router.huggingface.co/v1
HF_INFERENCE_API_KEY=your-hf-token
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
HF_RERANK_MODEL=BAAI/bge-reranker-base
HF_VISION_MODEL=ibm-granite/granite-docling-258M

# --- Vector store -----------------------------------------------------------
CHROMA_PERSIST_DIR=./.chroma
CHROMA_COLLECTION=mini_ai_kb
BM25_CACHE_PATH=./.chroma/bm25.pkl

# --- Memory (MongoDB Atlas free M0) -----------------------------------------
MONGODB_URI=mongodb+srv://user:pass@cluster0.mongodb.net/?appName=mini-ai
MONGODB_DB=mini_ai
MONGODB_COLLECTION=messages

# --- Runtime knobs ----------------------------------------------------------
RATE_LIMIT_PER_MIN=30
HEALTH_CACHE_TTL_SECONDS=10
MAX_CONTEXT_CHARS=8000
CONFIDENCE_GATE_THRESHOLD=0.62  # calibrated against tests/eval_set.jsonl

# --- Logging ----------------------------------------------------------------
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=52428800      # 50 MB
LOG_BACKUP_COUNT=5

# --- OpenTelemetry ----------------------------------------------------------
# When OTEL_EXPORTER_OTLP_ENDPOINT is empty, tracing is a NO-OP (zero cost).
#
# Option A — LOCAL stack (recommended for dev):
#   docker compose --profile obs up -d
#   cat .env.obs >> .env       # adds OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
#   docker compose restart api
#
# Option B — HOSTED backend (Honeycomb, Grafana Cloud, etc.):
#   # Sign up for the free tier, copy the OTLP endpoint + API key,
#   # then uncomment and edit the lines below.
#
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
#   OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_API_KEY
#
#   For Grafana Cloud:
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64-instance:apitoken>
#
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=mini-ai-assistant

# --- Built-in metrics (always on, no setup) --------------------------------
# The app exposes Prometheus-format metrics on http://localhost:8000/metrics
# — no extra services required. Hit it directly:
#
#   curl http://localhost:8000/metrics | grep -E '^(http_|request_|tool_|answerability_)'
#
# Counters you'll see: http_requests_total, request_stage_seconds (latency
# histogram), answerability_decisions_total, tool_calls_total, etc.
